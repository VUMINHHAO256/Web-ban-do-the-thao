# .env - Cấu hình môi trường MHShop
PORT=3000

# ============================================================
# === Cấu hình SQL Server ===
# ============================================================
# Tên server. Chỉ là tên máy/IP, KHÔNG bao gồm tên instance
# Ví dụ: localhost, 192.168.1.x, MáyTính\...
DB_SERVER=localhost
DB_PORT=1433

# Tên instance SQL Server (nếu dùng named instance)
# Ví dụ: SQLEXPRESS, MINHHAO, MSSQLSERVER
DB_INSTANCE=MINHHAO

# Tên database
DB_NAME=MHShopDB

# ============================================================
# === CHỌN MỘT TRONG HAI chế độ xác thực bên dưới ===
# ============================================================

# --- OPTION 1: Windows Authentication (khuyên dùng khi dev local) ---
# Dùng tài khoản Windows hiện tại, không cần user/pass
# DB_TRUSTED_CONNECTION=true

# --- OPTION 2: SQL Server Authentication ---
# Đặt DB_TRUSTED_CONNECTION=false rồi điền user/pass SQL Server của bạn
DB_TRUSTED_CONNECTION=false
DB_USER=mhshop
DB_PASSWORD=MHShop@2024

# ============================================================
# === JWT Secret ===
# ============================================================
# Thay bằng chuỗi ngẫu nhiên dài ≥ 32 ký tự khi deploy lên production!
JWT_SECRET=super_secret_jwt_key_for_mhshop_2024
